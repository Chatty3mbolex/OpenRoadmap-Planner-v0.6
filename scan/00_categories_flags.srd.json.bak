    { "id": "is_network",   "name": "Networking",      "appliesTo": ["SRV", "CLI"],              "description": "Networking related" },
    { "id": "is_story",     "name": "Story",           "appliesTo": ["VIS", "WLD"],              "description": "Narrative / story" }
  ]
