    { "id": "CLI",  "name": "Client Modules",     "prefix": "CLI",  "color": "#f59e0b", "description": "Client-side systems" },
    { "id": "GAM",  "name": "Gameplay",           "prefix": "GAM",  "color": "#ef4444", "description": "Gameplay mechanics" },
    { "id": "WLD",  "name": "World & Design",     "prefix": "WLD",  "color": "#14b8a6", "description": "World, levels, environment" },
    { "id": "ART",  "name": "Art & Assets",       "prefix": "ART",  "color": "#a855f7", "description": "Assets, visuals, audio" },
    { "id": "METH", "name": "Methods & Modules",  "prefix": "METH", "color": "#06b6d4", "description": "Implementation modules / methods" },
